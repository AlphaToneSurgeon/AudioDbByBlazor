@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Navigation

<CascadingAuthenticationState>
    <div class="app-shell">
        <nav class="navbar">
            <a href="/" class="brand">🎵 AudioDB</a>
            <div class="nav-links">
                <a href="/" class="nav-link">Recherche</a>
                <AuthorizeView>
                    <Authorized>
                        <a href="/favoris" class="nav-link">⭐ Mes Favoris</a>
                        <span class="nav-user">@context.User.Identity?.Name</span>
                        <form method="post" action="/account/logout">
                            <button type="submit" class="btn-logout">Déconnexion</button>
                        </form>
                    </Authorized>
                    <NotAuthorized>
                        <a href="/login" class="nav-link">Connexion</a>
                        <a href="/register" class="nav-btn">Inscription</a>
                    </NotAuthorized>
                </AuthorizeView>
            </div>
        </nav>

        <main class="main-content">
            @Body
        </main>

        <footer class="footer">
            <p>Données fournies par <a href="https://www.theaudiodb.com" target="_blank">TheAudioDB</a></p>
        </footer>
    </div>
</CascadingAuthenticationState>
