@page "/login"
@using AudioDBByBlazor.Models
@using Microsoft.AspNetCore.Identity
@inject SignInManager<AppUser> SignInManager
@inject NavigationManager Navigation
@inject IHttpContextAccessor HttpContextAccessor

<PageTitle>Connexion – AudioDB</PageTitle>

<div class="auth-page">
    <div class="auth-card">
        <h1>CONNEXION</h1>
        <p class="auth-subtitle">Accédez à vos favoris musicaux</p>

        @if (!string.IsNullOrEmpty(_error))
        {
            <div class="error-message">@_error</div>
        }

        <div class="form-group">
            <label class="form-label">Email</label>
            <input class="form-control" type="email" @bind="_email" placeholder="votre@email.com" />
        </div>

        <div class="form-group">
            <label class="form-label">Mot de passe</label>
            <input class="form-control" type="password" @bind="_password" placeholder="••••••" />
        </div>

        <button class="btn-submit" @onclick="HandleLogin" disabled="@_loading">
            @(_loading ? "Connexion..." : "Se connecter")
        </button>

        <p class="auth-link">
            Pas encore de compte ? <a href="/register">S'inscrire</a>
        </p>
    </div>
</div>

@code {
    private string _email = "";
    private string _password = "";
    private string _error = "";
    private bool _loading = false;

    [SupplyParameterFromQuery]
    private string? ReturnUrl { get; set; }

    private async Task HandleLogin()
    {
        _loading = true;
        _error = "";

        var result = await SignInManager.PasswordSignInAsync(_email, _password, false, false);

        if (result.Succeeded)
        {
            Navigation.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
        }
        else
        {
            _error = "Email ou mot de passe incorrect.";
            _loading = false;
        }
    }
}
